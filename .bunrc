# Bun 1.3.9+ 优化配置

# 启用实验性功能
experimental = true

# 性能优化
# 启用 JIT 编译
jit = true

# 内存优化
# 增加堆大小限制
maxHeapSize = "4GB"

# 启用并发垃圾回收
concurrentGC = true

# 优化事件循环
# 增加事件循环迭代次数
eventLoopIterations = 1000

# 启用微任务优化
microtaskOptimization = true

# WASM 优化
# 启用 WASM 垃圾回收
wasmGC = true

# 启用 WASM 多线程
wasmThreads = true

# 启用 WASM SIMD
wasmSIMD = true

# 网络优化
# 增加网络缓冲区大小
networkBufferSize = "64KB"

# 启用 HTTP/2
http2 = true

# 启用 HTTP/3
http3 = true

# 文件系统优化
# 启用文件系统缓存
fsCache = true

# 增加文件系统缓存大小
fsCacheSize = "128MB"

# 启用文件系统预读
fsPrefetch = true